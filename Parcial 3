#include <iostream>
#include <iomanip>
using namespace std;

float calcularPonderacion(float p, float proy, float f) {
    return p*0.30 + proy*0.25 + f*0.45;
}

void aplicarBonos(float &notaFinal, float notaExamenFinal, float asistencia, float notaPonderada) {
    if(asistencia >= 75) {
        if(notaPonderada >= 90 && asistencia >= 90) 
            notaFinal += notaPonderada * 0.05;
        if(notaExamenFinal > 85)
            notaFinal += 1;
    }
}

int main() {
    string nombre;
    float parcial, proyecto, examenFinal, asistencia;

    cout << "Nombre del estudiante: ";
    getline(cin, nombre);

    cout << "Nota examen parcial: ";
    cin >> parcial;
    cout << "Nota proyecto: ";
    cin >> proyecto;
    cout << "Nota examen final: ";
    cin >> examenFinal;
    cout << "Porcentaje de asistencia: ";
    cin >> asistencia;

    if(parcial < 0 || parcial > 100 || proyecto < 0 || proyecto > 100 ||
       examenFinal < 0 || examenFinal > 100 || asistencia < 0 || asistencia > 100) {
        cout << "ERROR: Datos fuera del rango permitido.\n";
        return 0;
    }

    float notaPonderada = calcularPonderacion(parcial, proyecto, examenFinal);
    float notaFinal = notaPonderada;

    aplicarBonos(notaFinal, examenFinal, asistencia, notaPonderada);

    cout << fixed << setprecision(2);
    cout << "\n--- RESULTADOS ---\n";
    cout << "Estudiante: " << nombre << endl;
    cout << "Notas: Parcial " << parcial << ", Proyecto " << proyecto << ", Final " << examenFinal << endl;
    cout << "Asistencia: " << asistencia << "%" << endl;
    cout << "Nota Ponderada: " << notaPonderada << endl;
    cout << "Nota Final Definitiva: " << notaFinal << endl;

    return 0;
}
