#include <iostream>
using namespace std;

int main() {
    int numero, digito, contador = 0;
    int total_horas = 0, mayores_5 = 0;

    cout << "Ingrese el numero: ";
    cin >> numero;

    int copia = numero;

    while (numero > 0) {
        digito = numero % 10;

        total_horas += digito;
        contador++;

        if (digito > 5) {
            mayores_5++;
        }

        numero = numero / 10;
    }

    double promedio = (double)total_horas / contador;

    cout << "\nNumero ingresado: " << copia << endl;
    cout << "Total de horas: " << total_horas << endl;
    cout << "Apps con uso > 5 horas: " << mayores_5 << endl;
    cout << "Promedio de uso: " << promedio << endl;

    return 0;
}
