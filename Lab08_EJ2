#include <iostream>
using namespace std;

int main() {
    int numero, digito;
    int mayor = -1, menor = 9;
    int contador_mayor = 0;

    cout << "Ingrese el numero: ";
    cin >> numero;

    int copia = numero;

    while (numero > 0) {
        digito = numero % 10;

        // Encontrar mayor
        if (digito > mayor) {
            mayor = digito;
            contador_mayor = 1;
        } else if (digito == mayor) {
            contador_mayor++;
        }

        // Encontrar menor
        if (digito < menor) {
            menor = digito;
        }

        numero = numero / 10;
    }

    cout << "\nNumero ingresado: " << copia << endl;
    cout << "Mayor consumo: " << mayor << endl;
    cout << "Menor consumo: " << menor << endl;
    cout << "El mayor se repite: " << contador_mayor << " veces" << endl;

    return 0;
}
